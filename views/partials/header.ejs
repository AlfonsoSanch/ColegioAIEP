<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Colegio AIEP - <%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <header class="dashboard-header">
    <div class="header-container">
      <div class="logo-section">
        <div class="logo">
          <i class="fas fa-graduation-cap"></i>
          <span>Colegio AIEP</span>
        </div>
      </div>
      
      <nav class="nav-menu">
        <div class="user-info">
          <div class="user-avatar">
            <i class="fas fa-user"></i>
          </div>
          <div class="user-details">
            <span class="user-name"><%= usuario.nombre %> <%= usuario.apellido_paterno %></span>
            <span class="user-role"><%= usuario.tipo %></span>
          </div>
        </div>
        
        <div class="nav-actions">
          <button class="nav-btn" onclick="toggleNotifications()">
            <i class="fas fa-bell"></i>
            <span class="badge">3</span>
          </button>
          <div class="dropdown">
            <button class="nav-btn" onclick="toggleDropdown()">
              <i class="fas fa-user-circle"></i>
            </button>
            <div class="dropdown-menu" id="userDropdown">
              <a href="/auth/profile"><i class="fas fa-user"></i> Mi Perfil</a>
              <a href="/auth/settings"><i class="fas fa-cog"></i> Configuración</a>
              <div class="dropdown-divider"></div>
              <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Cerrar Sesión</a>
            </div>
          </div>
        </div>
      </nav>
    </div>
  </header>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h3>Menú Principal</h3>
    </div>
    <nav class="sidebar-nav">
      <% if (usuario.tipo === 'Administrador') { %>
        <a href="/auth/dashadmin" class="nav-item active">
          <i class="fas fa-tachometer-alt"></i>
          <span>Dashboard Admin</span>
        </a>
        <a href="/auth/users" class="nav-item">
          <i class="fas fa-users"></i>
          <span>Usuarios</span>
        </a>
        <a href="/auth/reports" class="nav-item">
          <i class="fas fa-chart-bar"></i>
          <span>Reportes</span>
        </a>
        <a href="/auth/settings" class="nav-item">
          <i class="fas fa-cog"></i>
          <span>Configuración</span>
        </a>
      <% } else if (usuario.tipo === 'Docente') { %>
        <a href="/auth/teacher-dashboard" class="nav-item active">
          <i class="fas fa-chalkboard-teacher"></i>
          <span>Mi Dashboard</span>
        </a>
        <a href="/auth/courses" class="nav-item">
          <i class="fas fa-book"></i>
          <span>Mis Cursos</span>
        </a>
        <a href="/auth/students" class="nav-item">
          <i class="fas fa-user-graduate"></i>
          <span>Estudiantes</span>
        </a>
        <a href="/auth/grades" class="nav-item">
          <i class="fas fa-chart-line"></i>
          <span>Calificaciones</span>
        </a>
        <a href="/auth/schedule" class="nav-item">
          <i class="fas fa-calendar-alt"></i>
          <span>Horario</span>
        </a>
      <% } else if (usuario.tipo === 'Apoderado') { %>
        <a href="/auth/parent-dashboard" class="nav-item active">
          <i class="fas fa-home"></i>
          <span>Dashboard</span>
        </a>
        <a href="/auth/my-children" class="nav-item">
          <i class="fas fa-child"></i>
          <span>Mis Hijos</span>
        </a>
        <a href="/auth/grades" class="nav-item">
          <i class="fas fa-chart-line"></i>
          <span>Notas</span>
        </a>
        <a href="/auth/attendance" class="nav-item">
          <i class="fas fa-calendar-check"></i>
          <span>Asistencia</span>
        </a>
        <a href="/auth/communications" class="nav-item">
          <i class="fas fa-envelope"></i>
          <span>Comunicaciones</span>
        </a>
      <% } %>
    </nav>
  </aside>

  <main class="main-content" id="mainContent">
